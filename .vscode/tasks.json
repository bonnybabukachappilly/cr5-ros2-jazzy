{
    // sudo apt install python3-colcon-clean
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Colcon: Build",
            "type": "shell",
            "linux": {
                "command": "colcon build"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": []
        },
        {
            "label": "Colcon: Build [Symlink]",
            "type": "shell",
            "linux": {
                "command": "colcon build --symlink-install"
            },
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": []
        },
        {
            "label": "Colcon: Build Select",
            "type": "shell",
            "linux": {
                "command": "colcon build --packages-select ${input:ros_pkg_name}"
            },
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": []
        },
        {
            "label": "Colcon: Clean Build",
            "type": "shell",
            "linux": {
                "command": "colcon clean workspace -y"
            },
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": []
        },
        {
            "label": "ROS: Create Package",
            "type": "shell",
            "linux": {
                "command": "ros2 pkg create ${input:ros_pkg} --dependencies ${input:ros_pkg_dep} --build-type ${input:ros_build} --license ${input:ros_pkg_lic} --maintainer-name bonnybk --maintainer-email bonnybabukachappilly@gmail.com"
            },
            "options": {
                "cwd": "${workspaceFolder}/src"
            },
            "problemMatcher": []
        },
        // GROUP TASKS
        {
            "label": "Colcon: Clean & Build",
            "dependsOn": [
                "Colcon: Clean Build",
                "Colcon: Build",
            ],
            "dependsOrder": "sequence",
            "problemMatcher": []
        },
        {
            "label": "Colcon: Clean & Build [Symlink]",
            "dependsOn": [
                "Colcon: Clean Build",
                "Colcon: Build [Symlink]",
            ],
            "dependsOrder": "sequence",
            "problemMatcher": []
        },
        {
            "label": "Colcon: Clean, Create pkg & Build",
            "dependsOn": [
                "Colcon: Clean Build",
                "ROS: Create Package",
                "Colcon: Build",
            ],
            "dependsOrder": "sequence",
            "problemMatcher": []
        },
        {
            "label": "Colcon: Clean, Create pkg & Build [Symlink]",
            "dependsOn": [
                "Colcon: Clean Build",
                "ROS: Create Package",
                "Colcon: Build [Symlink]",
            ],
            "dependsOrder": "sequence",
            "problemMatcher": []
        },
        // RUNNING PROGRAMS
    ],
    "inputs": [
        {
            "id": "ros_build",
            "type": "pickString",
            "description": "ROS build type",
            "default": "ament_python",
            "options": [
                "ament_python",
                "ament_cmake"
            ]
        },
        {
            "id": "ros_pkg",
            "type": "promptString",
            "description": "ROS package name"
        },
        {
            "id": "ros_pkg_dep",
            "type": "promptString",
            "description": "ROS package dependencies"
        },
        {
            "id": "ros_pkg_lic",
            "type": "pickString",
            "description": "ROS package license",
            "default": "GPL-3.0-only",
            "options": [
                "Apache-2.0",
                "BSL-1.0",
                "BSD-2.0",
                "BSD-2-Clause",
                "BSD-3-Clause",
                "GPL-3.0-only",
                "LGPL-3.0-only",
                "MIT",
                "MIT-0",
            ]
        },
        {
            "id": "launch_select_description",
            "type": "pickString",
            "description": "Which launch file to run?",
            "default": "display.launch.py",
            "options": [
                "display.launch.py",
                "sim.launch.py"
            ]
        },
        {
            "id": "launch_select_moveit",
            "type": "pickString",
            "description": "Which launch file to run?",
            "default": "moveit_sim.launch.py",
            "options": [
                "moveit_sim.launch.py",
            ]
        },
        {
            "id": "ros_pkg_name",
            "type": "pickString",
            "description": "Which package you want to build?",
            "default": "cr5_driver",
            "options": [
                "cr5_driver",
                "cr5_msgs",
                "cr5_description"
            ]
        }
    ]
}